// Template: a new sealed Failure family for a boundary.
// Place in packages/core/lib/src/failures.dart (Flutter-free).
// RULES: stable `code` (localization-key-like) + TYPED params only — NEVER a
// user-facing/localized string. Every subtype is `final`; the family is `sealed`
// so UI switches are exhaustive with NO default:.

sealed class __Boundary__Failure extends Failure {
  const __Boundary__Failure();
}

// One subtype per distinct, recoverable condition the UI must handle 1:1.
final class __Condition__ extends __Boundary__Failure {
  const __Condition__(this.param); // typed params, e.g. `int requested`
  final __ParamType__ param;
  @override
  String get code => '__boundary__.__condition__'; // e.g. 'notif.pending_cap_exceeded'
}

final class __ConditionNoParams__ extends __Boundary__Failure {
  const __ConditionNoParams__();
  @override
  String get code => '__boundary__.__condition_no_params__';
}

